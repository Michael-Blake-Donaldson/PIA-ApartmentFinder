# ================================
# PIA — Environment Variables
# Copy this to .env and fill in real values
# ================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pia_db
DB_USERNAME=pia_user
DB_PASSWORD=changeme_strong_password

# --- JWT ---
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_minimum_48_characters_long_replace_in_production
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# --- Mail (SMTP) ---
# For dev, use Mailhog or Mailtrap
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@pia.local
# Set to smtp, sendgrid, resend for prod
MAIL_PROVIDER=smtp

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
VITE_MAP_PROVIDER=leaflet
# Obtain from https://www.maptiler.com or use OpenStreetMap tiles
VITE_MAPTILER_KEY=

# --- Geocoding ---
# Using Nominatim (free, no key required for dev)
# Replace with Google Maps / Mapbox in production
GEOCODING_PROVIDER=nominatim
GEOCODING_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# GEOCODING_GOOGLE_API_KEY=

# --- Parser ---
PARSER_REQUEST_TIMEOUT_SECONDS=15
PARSER_MAX_RETRIES=3
PARSER_RATE_LIMIT_RPS=2

# --- Admin ---
ADMIN_INITIAL_EMAIL=admin@pia.local
ADMIN_INITIAL_PASSWORD=changeme_admin_password

# --- Redis (optional) ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# --- App ---
APP_BASE_URL=http://localhost:5173
APP_NAME=PIA
